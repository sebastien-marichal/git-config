#!/bin/sh

log() {
	git log --graph --decorate --date=relative --format=format:'%C(auto)%h%Creset %C(yellow)%d%Creset %s %C(green)(%cr)%Creset %C(bold blue)<%an>%Creset' "$@"
}

if [ "$#" -gt 0 ]; then
	log "$@"
	exit
fi

remote="${GIT_L_REMOTE:-origin}"

branch=$(git symbolic-ref --quiet --short "refs/remotes/$remote/HEAD" 2>/dev/null || true)
branch=${branch#"$remote/"}

if [ -z "$branch" ]; then
	git remote set-head "$remote" --auto >/dev/null 2>&1 || true
	branch=$(git symbolic-ref --quiet --short "refs/remotes/$remote/HEAD" 2>/dev/null || true)
	branch=${branch#"$remote/"}
fi

if [ -z "$branch" ] || ! git rev-parse --verify --quiet "$remote/$branch^{commit}" >/dev/null; then
	log HEAD
	exit
fi

default_ref="$remote/$branch"
base=$(git merge-base HEAD "$default_ref" 2>/dev/null || true)

if [ -z "$base" ]; then
	echo "No common ancestor with $default_ref; showing both histories." >&2
	log HEAD "$default_ref"
	exit
fi

log HEAD "$default_ref" "^$base^@"
